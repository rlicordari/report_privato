# Copia questo file in .streamlit/secrets.toml per sviluppo locale
# Su Streamlit Cloud aggiungili in: App Settings → Secrets

# PIN di accesso all'app
APP_PIN = "il-tuo-pin"

# Token GitHub con permesso "repo" (Contents: read & write)
# Generalo su: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
GITHUB_TOKEN = "github_pat_..."

# Nome del repository nel formato "utente/nome-repo"
GITHUB_REPO = "tuo-username/report-privato"
